<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	  xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
	<id>talk_webhooks</id>
	<name>Talk Webhooks</name>
	<summary>Create incoming webhooks for Talk channels</summary>
	<description>A Nextcloud Talk bot that creates incoming webhook URLs, by which external systems can send messages to channels.</description>
	<version>1.0.0</version>
	<licence>AGPL-3.0-or-later</licence>
	<author mail="example@example.com" homepage="https://example.com">Example</author>
	<namespace>TalkWebhooks</namespace>
	<category>customization</category>
	<bugs>https://example.com/bugs</bugs>
	<dependencies>
		<nextcloud min-version="32" max-version="32"/>
		<php min-version="8.1"/>
	</dependencies>
	<repair-steps>
		<install>
			<step>OCA\TalkWebhooks\Migration\InstallBot</step>
		</install>
	</repair-steps>
</info>
